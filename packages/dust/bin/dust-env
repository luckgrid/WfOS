#!/usr/bin/env bash
# dust env — print the resolved Dust environment (paths, module map, DUST_AGENT state).
# Read-only and agent-safe.
#
#   dust env            resolved environment as KEY=value lines + a module map
#   dust env --shell    the shell activation snippet (config/shell/dust.zsh)
#   dust env --json     the resolved environment as a JSON object (paths + modules)
set -uo pipefail

_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$_self/../lib/common.sh"
# shellcheck source=../lib/manifest.sh
source "$_self/../lib/manifest.sh"

_json_escape() { printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g'; }

# Default-tool ids for a module, comma-joined.
_module_defaults() {
  dust_manifest_tsv | awk -F'\037' -v m="$1" '$1==m && $3=="true" {printf (n++?",":"") $2}'
}
# Alternative ids referenced by a module's tools, de-duplicated, comma-joined.
_module_alternatives() {
  dust_manifest_tsv | awk -F'\037' -v m="$1" '
    $1==m && $7!="" { n=split($7,a,","); for(i=1;i<=n;i++) if(!seen[a[i]]++) printf (c++?",":"") a[i] }'
}

cmd_shell() {
  local fragment="$DUST_CONFIG/shell/dust.zsh"
  [ -f "$fragment" ] || dust_die "missing shell fragment: $fragment"
  cat "$fragment"
}

cmd_json() {
  local agent="${DUST_AGENT:-0}"
  local home_resolved="${DUST_HOME:-$DUST_PKG}"
  printf '{\n'
  printf '  "paths": {\n'
  printf '    "dust_pkg": "%s",\n' "$(_json_escape "$DUST_PKG")"
  printf '    "dust_manifest": "%s",\n' "$(_json_escape "$DUST_MANIFEST")"
  printf '    "dust_config": "%s",\n' "$(_json_escape "$DUST_CONFIG")"
  printf '    "dust_bin": "%s",\n' "$(_json_escape "$DUST_BIN")"
  printf '    "dust_home": "%s",\n' "$(_json_escape "$home_resolved")"
  printf '    "wfos_root": "%s",\n' "$(_json_escape "$WFOS_ROOT")"
  printf '    "archon_pkg": "%s",\n' "$(_json_escape "$ARCHON_PKG")"
  printf '    "archon_registry": "%s"\n' "$(_json_escape "$ARCHON_REGISTRY")"
  printf '  },\n'
  printf '  "agent": %s,\n' "$([ "$agent" = "1" ] && echo true || echo false)"
  printf '  "manifest_version": "%s",\n' "$(dust_manifest_version)"
  printf '  "modules": {\n'
  local first=1 m defs alts
  while IFS= read -r m; do
    [ -n "$m" ] || continue
    [ "$first" = "1" ] || printf ',\n'
    first=0
    defs="$(_module_defaults "$m")"
    alts="$(_module_alternatives "$m")"
    printf '    "%s": {"default": [%s], "alternatives": [%s]}' "$m" \
      "$(printf '%s' "$defs" | awk -F',' '{for(i=1;i<=NF;i++) printf (i>1?",":"") "\"" $i "\""}')" \
      "$(printf '%s' "$alts" | awk -F',' '{for(i=1;i<=NF;i++) if($i!="") printf (c++?",":"") "\"" $i "\""}')"
  done < <(dust_manifest_modules)
  printf '\n  }\n'
  printf '}\n'
}

cmd_resolved() {
  local home_resolved
  if [ -n "${DUST_HOME:-}" ]; then home_resolved="$DUST_HOME"; else home_resolved="(unset; resolves to $DUST_PKG)"; fi
  printf 'DUST_PKG=%s\n'         "$DUST_PKG"
  printf 'DUST_MANIFEST=%s\n'    "$DUST_MANIFEST"
  printf 'DUST_CONFIG=%s\n'      "$DUST_CONFIG"
  printf 'DUST_BIN=%s\n'         "$DUST_BIN"
  printf 'DUST_HOME=%s\n'        "$home_resolved"
  printf 'WFOS_ROOT=%s\n'        "$WFOS_ROOT"
  printf 'ARCHON_PKG=%s\n'       "$ARCHON_PKG"
  printf 'ARCHON_REGISTRY=%s\n'  "$ARCHON_REGISTRY"
  printf 'DUST_AGENT=%s\n'       "${DUST_AGENT:-0}"
  printf 'manifest_version=%s\n' "$(dust_manifest_version)"
  printf 'modules=%s\n' "$(dust_manifest_modules | paste -sd, -)"
  echo
  printf '%smodule map (default tools)%s\n' "$_C_BOLD" "$_C_RESET"
  local m defs
  while IFS= read -r m; do
    [ -n "$m" ] || continue
    defs="$(_module_defaults "$m" | sed 's/,/, /g')"
    printf '  %-10s %s%s%s\n' "$m" "$_C_DIM" "${defs:-—}" "$_C_RESET"
  done < <(dust_manifest_modules)
}

main() {
  case "${1:-}" in
    --shell) cmd_shell ;;
    --json)  cmd_json ;;
    ""|--resolved) cmd_resolved ;;
    -h|--help) printf 'usage: dust env [--shell|--json]\n' ;;
    *) dust_err "unknown flag: $1"; printf 'usage: dust env [--shell|--json]\n' >&2; exit 1 ;;
  esac
}

main "$@"
