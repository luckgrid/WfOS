{{- $p := index .profiles .profile -}}
# ~/.config/zsh/rtk.zsh — managed by chezmoi (WfOS). Profile: {{ .profile }}
#
# Wires RTK (the recommended-default output compressor) from profile data. RTK INSTALL is owned
# by `dust bootstrap` / the manifest `agent` module; this fragment owns the chezmoi integration
# and the profile-driven on/off, then sources the single authoritative Dust RTK layer so the
# routing logic lives in one place (config/shell/rtk.zsh).
{{ if $p.rtk -}}
export DUST_RTK=1
{{- else -}}
export DUST_RTK=0
{{- end }}

# Tell dust.zsh not to also source the RTK layer (this fragment is authoritative here).
export DUST_RTK_MANAGED=1

# Source the Dust RTK layer (guarded; safe when rtk is absent). DUST_HOME is set by dust.zsh.
_wfos_rtk_frag="${DUST_HOME:-$HOME/Workstreams/Build/src/workspaces/wfos/packages/dust}/config/shell/rtk.zsh"
[ -f "$_wfos_rtk_frag" ] && source "$_wfos_rtk_frag"
unset _wfos_rtk_frag
