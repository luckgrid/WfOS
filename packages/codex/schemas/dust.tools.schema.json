{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wfos/codex/schemas/dust.tools.schema.json",
  "title": "Dust tools registry",
  "description": "Generated by `dust doctor` from manifest/dust.tools.toml.",
  "type": "object",
  "required": ["generated_at", "manifest_version", "summary", "tools"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "manifest_version": { "type": "string" },
    "host": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["total", "installed", "missing", "missing_default"],
      "properties": {
        "total": { "type": "integer" },
        "installed": { "type": "integer" },
        "missing": { "type": "integer" },
        "missing_default": { "type": "integer" }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "id", "installed", "default", "agent_safe", "detect"],
        "properties": {
          "module": { "type": "string" },
          "id": { "type": "string" },
          "installed": { "type": "boolean" },
          "default": { "type": "boolean" },
          "agent_safe": { "type": "boolean" },
          "detect": { "type": "string" },
          "brew": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    }
  }
}
